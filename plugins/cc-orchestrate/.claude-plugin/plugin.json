{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "cc-orchestrate",
  "version": "0.12.0",
  "description": "Drive cc-orchestrate agent fleets from Claude — the cco CLI command surface, the repo/workstream/sprint/agent model, the five backends, and the spawn/watch/message/kill flow.",
  "author": {
    "name": "yasyf",
    "email": "yasyf@yasyf.com",
    "url": "https://github.com/yasyf"
  },
  "homepage": "https://github.com/yasyf/cc-orchestrate",
  "repository": "https://github.com/yasyf/cc-orchestrate",
  "license": "PolyForm-Noncommercial-1.0.0",
  "mcpServers": {
    "cc-orchestrate": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/cco",
      "args": [
        "channel"
      ]
    }
  },
  "channels": [
    {
      "server": "cc-orchestrate",
      "displayName": "cc-orchestrate"
    }
  ],
  "keywords": [
    "cc-orchestrate",
    "claude-code",
    "agents",
    "orchestration",
    "fleet"
